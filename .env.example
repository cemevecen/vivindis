# ——— Genel ———
ENVIRONMENT=

# ——— PostgreSQL (Docker / Supabase) ———
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=
DATABASE_ECHO=

# ——— Redis / Celery ———
# rediss://… için ssl_cert_reqs: backend yoksa CERT_NONE ekler (Celery zorunluluğu).
REDIS_URL=
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ——— FastAPI ———
API_HOST=
API_PORT=
SECRET_KEY=
ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=
CORS_ORIGINS=
LOG_LEVEL=

# ——— Clerk ———
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
CLERK_JWKS_URL=
CLERK_JWT_ISSUER=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ——— Frontend ———
NEXT_PUBLIC_API_URL=
# Vercel: NEXT_PUBLIC_API_URL boşken aynı origin /api/v1 → backend proxy (CORS gerekmez)
BACKEND_ORIGIN=
NEXT_PUBLIC_APP_URL=

# ——— AI ———
GEMINI_API_KEY=
GEMINI_MODEL=
GROQ_API_KEY=
OPENAI_API_KEY=

# ——— Scraper (Celery review_fetch_task) ———
SCRAPE_PLAY_LANG=
SCRAPE_PLAY_COUNTRY=
SCRAPE_APP_STORE_COUNTRY=
SCRAPE_PLAY_SLEEP_SECONDS=
SCRAPE_APP_STORE_SLEEP_SECONDS=
SCRAPE_MAX_REVIEWS=
SCRAPE_PLAY_GLOBAL_LOCALE_LIMIT=
SCRAPE_APP_STORE_GLOBAL_COUNTRY_LIMIT=
SCRAPE_HTTP_TIMEOUT_SECONDS=
# Play + App Store RSS: saniyede izin verilen istek sayısı (5–10 önerilir)
SCRAPE_REQUESTS_PER_SECOND=

# ——— Flower ———
FLOWER_PORT=
FLOWER_BASIC_AUTH=

# ——— Büyük çekim yönetici onayı (WhatsApp veya Telegram) ———
# FETCH_APPROVAL_DISABLED=true → eşik/onay devre dışı (her zaman anında kuyruk).
# FETCH_APPROVAL_REVIEW_THRESHOLD=1000 → üstü veya review_limit boş → WAITING_APPROVAL.
FETCH_APPROVAL_DISABLED=
FETCH_APPROVAL_REVIEW_THRESHOLD=
# Bildirim: Twilio WhatsApp dört alan doluysa önce o kullanılır; değilse Telegram.
# Twilio konsol: WhatsApp sandbox veya onaylı işletme hattı gerekir.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Örn. whatsapp:+14155238886 (sandbox) veya Meta onaylı gönderen.
TWILIO_WHATSAPP_FROM=
# Yönetici: whatsapp:+905551234567 veya +905551234567
TWILIO_WHATSAPP_TO=
TELEGRAM_BOT_TOKEN=
# Virgülle ayrılmış chat id (ör. @userinfobot / getUpdates).
TELEGRAM_ADMIN_CHAT_IDS=
# Onay linki: https://api.vivindis.com gibi Railway public API kökü (sonunda / yok).
PUBLIC_API_BASE_URL=
